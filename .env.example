# ============================================================
# RCRP Management Bot — Environment Variables
# Set these in Railway Dashboard → Variables.
# DO NOT commit a .env file with real values to GitHub.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=

# Discord Application/Client ID (from Developer Portal)
CLIENT_ID=

# Your RCRP Discord Server ID
GUILD_ID=

# ── OPTIONAL BUT RECOMMENDED ──────────────────────────────────

# ERLC Private Server API Key
# How to get it:
#   1. Open ERLC → your private server → Settings
#   2. Copy the "Server Key" from the API section
#   3. Paste it here
# Without this, all /game commands will show "No data available"
ERLC_API_KEY=

# NVIDIA NIM AI API Key
# How to get it:
#   1. Go to https://build.nvidia.com
#   2. Sign in (free account)
#   3. Click your profile icon → API Keys → Generate Key
#   4. Copy the key (starts with "nvapi-...")
# Without this, AI features (application analysis, @mentions, dispatch) are disabled
# but the bot will still work — it just falls back to generic responses.
AI_API_KEY=

# ── ERLC WEBHOOK (Optional) ───────────────────────────────────
# ERLC can send game events (joins, kills, commands) to a webhook URL.
# To set this up:
#   1. In ERLC → Private Server Settings → Webhook URL
#   2. Paste your Railway deployment URL + /erlc-webhook
#      Example: https://your-service.up.railway.app/erlc-webhook
# Note: This is for real-time push events, not required — the bot
#       polls the ERLC API every 20s automatically.
ERLC_WEBHOOK_SECRET=
